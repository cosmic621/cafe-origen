cat > .gitignore << 'EOF'
# Base de datos (se genera automáticamente)
cafe.db

# Dependencias
node_modules/
frontend/node_modules/

# Variables de entorno
.env
.env.local
.env.production

# Builds
frontend/dist/
frontend/build/
dist/

# Sistema operativo
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# IDE
.vscode/
.idea/
EOF